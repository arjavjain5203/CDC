{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CP Run",
            "type": "shell",
            "command": "g++ -std=c++17 -O2 -Wall \"${file}\" -o \"${fileBasenameNoExtension}\" && ./${fileBasenameNoExtension} < input.txt > output.txt",
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}